# ----------------------------------------------------------------------------
# Account Abstraction Platform — environment variables
# Copy this file to `.env.local` and fill in the values.
# NEXT_PUBLIC_* vars are exposed to the browser — RESTRICT each key by domain
# in its provider dashboard.
# ----------------------------------------------------------------------------

# Privy — https://dashboard.privy.io
# Auth (email/social/wallet), embedded EOA, EIP-7702 authorization, key export.
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Pimlico — https://dashboard.pimlico.io
# ERC-4337 bundler + gas-sponsoring paymaster (EntryPoint v0.7).
NEXT_PUBLIC_PIMLICO_API_KEY=

# Alchemy — https://dashboard.alchemy.com  (server-side only)
# Portfolio API (token balances + prices), RPC. Used by app/api/portfolio.
ALCHEMY_API_KEY=
